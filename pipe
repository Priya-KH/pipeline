pipeline {
    agent any

    stages {
        stage('Clone') {
            steps {
                git branch: 'main', url: 'https://github.com/Priya-KH/SIMPLEMAVEN.git'
            }
        }

        stage('Build') {
            steps {
                sh 'mvn clean compile'
            }
        }

        stage('Test') {
            steps {
                sh 'mvn test'
            }
        }
    }
}

sudo apt install ansible -y
ansible --version

nano hosts.ini
[local]
localhost ansible_connection=local

nano setup.yml
---
- name: Basic Server Setup
  hosts: local
  become: yes

  tasks:
    - name: Update apt cache
      apt:
        update_cache: yes

    - name: Install curl
      apt:
        name: curl
        state: present

 ansible-playbook -i hosts.ini setup.yml --ask-become-pass
